stocks.index


# 컬럼제거 : 필요없는 행이나 열을 제거
new_stocks = stocks.drop('ISU_CD',axis=1)
new_stocks_desc = stocks_desc.drop(['Name', 'Market'],axis=1)
print(new_stocks.columns)
print(new_stocks_desc.columns)





import pandas as pd


pd.merge?


# new_stocks join new_stocks_desc
