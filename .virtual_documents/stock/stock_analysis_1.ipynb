# 출력 폭을 설정하여 긴 데이터 프레임도 잘리지 않도록 설정
pd.set_option('display.width', 1000)  # 원하는 폭으로 설정


df_stocks = pd.read_excel('stocks.xlsx')


df_stocks.shape


df_stocks.head(1)


df_stocks.info()


df_stocks.describe()


# 모든 숫자 컬럼에 대해 1000 단위 콤마 및 소수점 두 자리 표현 적용
def format_numbers(x):
    if isinstance(x, float):
        return f"{x:,.2f}"
    elif isinstance(x, int):
        return f"{x:,}"
    else:
        return x  # 숫자가 아닌 경우 그대로 반환

# 숫자 컬럼만 선택하여 포맷팅 적용
df_numeric = df_stocks.select_dtypes(include=['number'])  # 숫자 컬럼 선택
# display(df_numeric)
df_stocks[df_numeric.columns] = df_numeric.map(format_numbers)  # 포맷팅 적용


